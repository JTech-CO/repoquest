{
  "name": "github-learn-emulator",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "백엔드 없이 브라우저에서 Git/GitHub 동작을 시뮬레이션하는 학습용 에뮬레이터 (비공식, GitHub과 무관).",
  "scripts": {
    "dev": "vite",
    "build": "rimraf dist && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@primer/octicons-react": "^19.12.0",
    "highlight.js": "^11.11.1",
    "immer": "^10.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^3.1.0"
  }
}
